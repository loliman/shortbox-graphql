{
  "name": "shortbox-graphql",
  "version": "0.0.0",
  "private": true,
  "main": "src/app.js",
  "scripts": {
    "contract:codegen": "npm --prefix ../shortbox-contract run codegen",
    "start": "ts-node src/app.ts",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "jest",
    "codegen": "npm run contract:codegen",
    "prebuild": "npm run contract:codegen",
    "build": "npx tsc",
    "serve": "node dist/app.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "start:mock": "MOCK_MODE=true ts-node src/app.ts"
  },
  "keywords": [],
  "dependencies": {
    "@shortbox/contract": "file:../shortbox-contract",
    "@apollo/server": "5.4.0",
    "axios": "^1.13.5",
    "cheerio": "^1.1.2",
    "cron": "^1.8.2",
    "dataloader": "^2.2.3",
    "dateformat": "^3.0.3",
    "dotenv": "^17.2.3",
    "graphql": "^16.12.0",
    "graphql-relay": "^0.10.2",
    "graphql-sequelize": "^9.5.1",
    "graphql-tag": "^2.12.6",
    "lodash": "^4.17.21",
    "mysql2": "^3.16.0",
    "sequelize": "^6.37.7",
    "shelljs": "^0.10.0",
    "winston": "^3.19.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/cron": "^2.0.1",
    "@types/dateformat": "^5.0.3",
    "@types/lodash": "^4.17.21",
    "@types/node": "^25.0.3",
    "@types/shelljs": "^0.10.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
